<link rel="stylesheet" href="{{ 'sections/styles/latestcollection.css' | asset_url }}">

<section class="collection">
  <div class="title">
    <span><img
        class="iconstart external-star"
        src="{{ 'accessories/start.svg' | asset_url }}"
        alt="icon"></span>
    <h2>
      <span class="inline-star star-one"><img
          class="star-inline"
          src="{{ 'accessories/start.svg' | asset_url }}"
          alt="icon">
      </span>
      LATEST
      <span class="inline-star star-two"><img
          class="star-inline"
          src="{{ 'accessories/start.svg' | asset_url }}"
          alt="icon"></span>
      COLLECTION
    </h2>
    <span><img
        class="iconstart external-star"
        src="{{ 'accessories/start.svg' | asset_url }}"
        alt="icon"></span>
  </div>
  <div class="images">
    {% comment %}Filter and display only collections from 2025 onwards in a clean 2-column grid{% endcomment %}
    {% assign filtered_collections = '' %}
    {% assign filtered_count = 0 %}

    {% for collection in collections %}
      {% assign collection_year = collection[1].created_at | date: '%Y' | plus: 0 %}
      {% if collection_year >= 2025 and filtered_count < 4 %}
        <div class="collection-item">
          <a onclick="showAlert('{{ collection[1].title }}')" href="">
            <img
              src="{{ collection[1].image | prepend: 'img/' | asset_url }}"
              alt="{{ collection[1].title }}"
              width="400"
              height="400">
            <div class="collection-overlay">
              <h3>{{ collection[1].title }}</h3>
            </div>
          </a>
        </div>
        {% assign filtered_count = filtered_count | plus: 1 %}
      {% endif %}
    {% endfor %}
  </div>
</section>

<script>
  function showAlert(collectionName) {
   alert('Functionality to direct to another tab for: ' + collectionName);    
  }
</script>