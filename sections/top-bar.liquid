<link rel="stylesheet" href="{{ 'sections/styles/top-bar.css' | asset_url }}">
<section class="topbar">
  <div class="marquee-container">
    <h2>
      {%- for i in (1..20) -%}
        {{ settings['top-bar'].settings.marquee_text }}
        {%- unless forloop.last -%}&nbsp;&nbsp;&nbsp;&nbsp;{%- endunless -%}
      {%- endfor -%}
    </h2>
  </div>
  <div class="gradient"></div>
</section>