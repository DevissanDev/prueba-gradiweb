{% comment %} 
     Product Card Component
      
     Variables que recibe: 
     - product: Objeto con los datos del producto 
     - product.id: ID del producto 
     - product.title: Título del producto 
     - product.price: Precio del producto 
     - product.tags: Array de tags del producto 
     - product.image: Nombre de la imagen 
     - product.description: Descripción del producto 
{% endcomment %}
<link rel="stylesheet" href="{{ 'snippets/styles/product-card.css' | asset_url }}">
<article
  class="product-card"
  itemscope
  itemtype="https://schema.org/Product">
    <!-- Tags SEO ocultos -->
  <meta itemprop="productID" content="{{ product.id }}">
  <meta itemprop="category" content="{{ product.tags[0] }}">
  <meta itemprop="description" content="{{ product.description | default: 'Descripción del producto' }}">
  {% for tag in product.tags %}
    <meta itemprop="keywords" content="{{ tag }}">
  {% endfor %}
  <link itemprop="availability" href="https://schema.org/InStock">
  <div class="product-card__image-wrapper">
    <div class="product-card__image-container">
      <img
        src="/assets/img/{{ product.image | default: 'shuffle_crewneck_black.avif' }}"
        alt="{{ product.title | default: 'Imagen del producto' }}"
        itemprop="image" />
    </div>
  </div>
  <div class="product-card__footer">
    <div class="product-card__details">
      <h2 itemprop="name">{{ product.title | default: 'Producto Camiseta' }}</h2>
      <span
        itemprop="offers"
        itemscope
        itemtype="https://schema.org/Offer">
        <span itemprop="priceCurrency" content="USD">$</span>
        <span itemprop="price" content="{{ product.price }}">{{ product.price | default: '69.98 USD' }}</span>
      </span>
    </div>
    <div class="product-card__add-to-cart-btn">
      <div>
        <img
          src="/assets/accessories/cart.svg"
          alt="Añadir al carrito"
          itemprop="image" />
      </div>
    </div>
  </div>
</article>