{% comment %} 
      View All Products Card Component 
    
      Card especial para mostrar "Ver todos los productos" 
      con las mismas dimensiones que las product cards 
{% endcomment %}
<link rel="stylesheet" href="{{ 'snippets/styles/view-all-card.css' | asset_url }}">
<article class="product-card view-all-card">
  <div class="product-image view-all-image">
    <div class="img-container view-all-container">
      <div class="view-all-content">
        <div class="view-all-icon">
          <svg
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="currentColor">
            <path d="M4 4h4v4H4V4zm6 0h4v4h-4V4zm6 0h4v4h-4V4zM4 10h4v4H4v-4zm6 0h4v4h-4v-4zm6 0h4v4h-4v-4zM4 16h4v4H4v-4zm6 0h4v4h-4v-4zm6 0h4v4h-4v-4z" />
          </svg>
        </div>
        <h3 class="view-all-title">VIEW ALL</h3>
        <p class="view-all-description">Explore our full collection</p>
      </div>
    </div>
  </div>
  <div class="info-cart-container">
    <div class="product-info">
      <h2>Complete Catalog</h2>
      <span>Discover more</span>
    </div>
    <div class="cart-button view-all-button">
      <div>
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor">
          <path d="M8 1L15 8L8 15L7 14L13 8L7 2L8 1Z" />
        </svg>
      </div>
    </div>
  </div>
</article>