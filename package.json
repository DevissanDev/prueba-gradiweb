{
  "name": "shopify-simulator",
  "version": "1.0.2",
  "description": "Shopify simulator template",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"webpack serve --mode=development\" \"nodemon server.js\"",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "watch": "webpack --mode=development --watch"
  },
  "keywords": [
    "shopify",
    "javascript",
    "liquid"
  ],
  "author": "miguelgradi",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2",
    "liquidjs": "^10.20.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.1",
    "css-loader": "^6.7.3",
    "cssnano": "^7.1.1",
    "mini-css-extract-plugin": "^2.9.4",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "sass": "^1.62.0",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.2",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
